{
    "application.shellEnvironmentResolutionTimeout": 20,
    "breadcrumbs.enabled": true,
    "[css]": {
        "editor.tabSize": 2
    },
    "editor.rulers": [
        80,
        88,
        120
    ],
    "editor.formatOnPaste": false,
    "editor.acceptSuggestionOnEnter": "smart",
    "editor.codeActionsOnSave": {
        "source.organizeImports": "explicit"
    },
    "editor.mouseWheelZoom": false,
    "editor.find.cursorMoveOnType": true,
    "editor.suggestSelection": "first",
    "editor.suggest.showStatusBar": true,
    "editor.formatOnSave": true,
    "editor.detectIndentation": false,
    "editor.suggest.localityBonus": true,
    "editor.inlineSuggest.enabled": true,
    "editor.renderWhitespace": "boundary",
    "editor.tabCompletion": "on",
    "editor.wordWrap": "on",
    "editor.bracketPairColorization.enabled": true,
    "editor.peekWidgetDefaultFocus": "editor",
    "editor.stablePeek": true,
    "editor.tabSize": 4,
    "eslint.enable": true,
    "eslint.validate": [
        "javascript",
        "javascriptreact",
        "typescript",
        "typescriptreact"
    ],
    "explorer.confirmDragAndDrop": false,
    "explorer.confirmDelete": false,
    "explorer.sortOrder": "type",
    "extensions.autoUpdate": true,
    "files.autoSave": "afterDelay",
    "files.trimFinalNewlines": true,
    "files.insertFinalNewline": true,
    "git.autofetch": true,
    "git.enableSmartCommit": true,
    "git.mergeEditor": true,
    "[javascript]": {
        "editor.tabSize": 2,
        "editor.defaultFormatter": "vscode.typescript-language-features"
    },
    "[typescript]": {
        "editor.tabSize": 2,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[dockercompose]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "editor.autoIndent": "advanced",
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "[github-actions-workflow]": {
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "notebook.cellToolbarLocation": {
        "default": "right",
        "jupyter-notebook": "left"
    },
    "notebook.compactView": true,
    "notebook.cellFocusIndicator": "gutter",
    "python.languageServer": "Pylance",
    "python.defaultInterpreterPath": "/opt/anaconda3/envs/all/bin/python",
    "python.terminal.executeInFileDir": true,
    "pylint.interpreter": [
        "/opt/anaconda3/envs/all/bin/python"
    ],
    "pylint.args": [
        "--max-line-length",
        "120"
    ],
    "[python]": {
        "editor.formatOnSave": true,
        "editor.formatOnPaste": false,
        "editor.tabSize": 4,
        "editor.defaultFormatter": "ms-python.black-formatter",
        "editor.formatOnType": true
    },
    "isort.args": [
        "--src=${workspaceFolder}",
        "--profile=black",
        "--line-length=120",
        "--tc",
        "-m=VERTICAL_HANGING_INDENT"
    ],
    "black-formatter.args": [
        "--line-length",
        "120",
        "--skip-string-normalization"
    ],
    "flake8.args": [
        "--max-line-length",
        "120"
    ],
    "remote.SSH.showLoginTerminal": false,
    "remote.SSH.connectTimeout": 60,
    "terminal.integrated.inheritEnv": true,
    "terminal.integrated.defaultProfile.osx": "zsh",
    "window.title": "${activeEditorMedium}${separator}${rootName}",
    "workbench.editor.highlightModifiedTabs": true,
    "workbench.colorCustomizations": {
        "editorRuler.foreground": "#131591",
        "tab.activeBackground": "#395b4e",
        "tab.activeForeground": "#ffffff",
        "tab.inactiveBackground": "#1e1e1e",
        "tab.inactiveForeground": "#888888"
    },
    "workbench.settings.editor": "json",
    "workbench.editor.wrapTabs": true,
    "workbench.editor.decorations.colors": true,
    "workbench.editor.decorations.badges": true,
    "workbench.iconTheme": "material-icon-theme",
    "workbench.editorAssociations": {
        "*.ipynb": "jupyter-notebook"
    },
    "security.workspace.trust.untrustedFiles": "open",
    "jupyter.askForKernelRestart": false,
    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:gpt-4.1"
}
